{
  "buildCommand": "echo 'Single-page app - no build needed'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://siscon-backend.onrender.com/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
